# OpenAI (para o agente de IA)
OPENAI_API_KEY=sk-...

# Google Cloud - use Application Default Credentials ou service account
# Opção 1: gcloud auth application-default login
# Opção 2: caminho para JSON da service account
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/sua-service-account.json

# Opcional: projeto GCP (se não estiver no JSON)
# GOOGLE_CLOUD_PROJECT=seu-projeto-id

# Dataset BigQuery: por padrão o código usa bigquery-public-data.thelook_ecommerce.
# Se não definir BIGQUERY_DATASET, esse padrão é usado. Para usar o thelook explicitamente:
# BIGQUERY_DATASET=bigquery-public-data.thelook_ecommerce
# (ou apague a linha para usar o padrão)

# JWT (opcional): se preenchido, a rota POST /api/ask exige header "Authorization: Bearer <token>"
# Deixe vazio para desenvolvimento; em produção defina um segredo forte.
# JWT_SECRET=

# Login (só usado quando JWT_SECRET está definido): usuário e senha fixos para POST /api/login
# LOGIN_USER=admin
# LOGIN_PASSWORD=suasenha
